generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  level     String?
  isPrivate Boolean  @default(false)

  // AUTH
  token       Token?
  resetTokens PasswordResetToken[]

  // FORUM
  comments   Comment[]
  topics     Topic[]
  topicViews TopicView[]

  // POSTS
  posts        Post[]        @relation("UserPosts")
  postComments PostComment[] @relation("UserPostComments")
  postLikes    PostLike[]    @relation("UserPostLikes")
  postViews    PostView[]

  // TUTORIALS
  tutorials     Tutorial[]     @relation("UserTutorials")
  tutorialLikes TutorialLike[] @relation("UserTutorialLikes")
  tutorialViews TutorialView[]

  // GARDEN
  gardenData      GardenData?
  gardenVegetable GardenVegetable[]
  gardenSpaces    GardenSpace[]
  Task            Task[]

  @@index([email])
}

model Token {
  id        String   @id
  createdAt DateTime @default(now())
  expireAt  DateTime

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expireAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  expireAt  DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expireAt])
  @@map("PasswordResetToken")
}

model GardenVegetable {
  id          String   @id @default(uuid())
  vegetableId String
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]
}

model GardenSpace {
  id        String   @id @default(uuid())
  spaceName String
  area      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GardenData {
  id       String @id @default(uuid())
  name     String
  location String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  category    String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  reminder    Boolean      @default(false)
  completed   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  plantId String?
  plant   GardenVegetable? @relation(fields: [plantId], references: [id])

  gardenDataId String?
  gardenData   GardenData? @relation(fields: [gardenDataId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ForumTag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  topics TopicTag[]
}

model Topic {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  viewCount Int      @default(0)
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  comments Comment[]
  tags     TopicTag[]
  views    TopicView[]

  @@index([authorId])
  @@index([createdAt])
}

model TopicView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
}

model TopicTag {
  topicId String
  tagId   String

  topic Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  tag   ForumTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([topicId, tagId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([authorId])
}

model Post {
  id        String   @id @default(cuid())
  content   String   @db.Text
  images    String[]
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)

  comments PostComment[]
  likes    PostLike[]
  views    PostView[]

  @@index([authorId])
  @@index([createdAt])
}

model PostView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserPostLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("UserPostComments", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model Tutorial {
  id            String           @id @default(cuid())
  title         String
  description   String?          @db.Text
  type          TutorialType
  category      TutorialCategory
  videoUrl      String?
  videoDuration Int?
  thumbnail     String?
  content       String?          @db.Text
  images        String[]
  viewCount     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  authorId String
  author   User   @relation("UserTutorials", fields: [authorId], references: [id], onDelete: Cascade)

  likes TutorialLike[]
  views TutorialView[]

  @@index([authorId])
  @@index([type])
  @@index([category])
  @@index([createdAt])
}

model TutorialView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tutorialId, userId])
}

model TutorialLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserTutorialLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tutorialId, userId])
  @@index([tutorialId])
  @@index([userId])
}

model sensor_readings {
  id            BigInt    @id @default(autoincrement())
  sensor_id     String    @db.Uuid
  value_numeric Float
  raw_value     Int?
  voltage       Float?
  recorded_at   DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  sensors sensors @relation(fields: [sensor_id], references: [id], onDelete: Cascade)

  @@index([sensor_id, created_at(sort: Desc)], map: "idx_readings_sensor_created")
  @@index([sensor_id, recorded_at(sort: Desc)], map: "idx_readings_sensor_recorded")
}

model sensors {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  type        String
  unit        String   @default("%")
  is_active   Boolean  @default(true)
  write_token String?  @unique
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  sensor_readings sensor_readings[]
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TutorialType {
  VIDEO
  ARTICLE
}

enum TutorialCategory {
  ASTUCES
  DIY
  TECHNIQUES
}
